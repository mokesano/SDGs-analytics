```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
# Wizdam AI-scola .gitignore

# Database
/database/wizdam.db
/database/*.db
/database/*.sqlite

# Runtime / Storage
/storage/
/api/cache/
/logs/*.log
!/logs/.gitkeep

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Editors
.vscode/
.idea/

# Logs and temp files
*.log
*.tmp
*.swp

# OS generated files
.DS_Store
Thumbs.db

# Build directories
dist/
build/
target/
```