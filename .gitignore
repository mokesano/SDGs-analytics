# SDGs Analytics .gitignore

# Compiled and build artifacts
*.pyc
__pycache__/

# Database
/database/wizdam.db
/database/*.db
/database/*.sqlite

# Runtime / Storage
/storage/
/api/cache/
/logs/*.log
!/logs/.gitkeep

# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/
frontend/package-lock.json
backend/package-lock.json
venv/
.venv/
.env
.env.local
.env.*
package-lock.json
composer.lock

# Editors
.vscode/
.idea/

# Logs and temp files
*.log
*.tmp
*.swp

# OS generated files
.DS_Store
Thumbs.db

# Build directories
dist/
build/
target/
