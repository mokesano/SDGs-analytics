{
    "name": "wizdam/sdgs-analytics",
    "description": "SDGs Classification Analysis Platform — AI-powered research SDG mapping",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Rochmady",
            "email": "rochmady@sangia.org",
            "homepage": "https://orcid.org/0000-0002-5152-9727"
        }
    ],
    "require": {
        "php": ">=8.1",
        "delight-im/auth": "^4.0",
        "guzzlehttp/guzzle": "^7.8",
        "andreskrey/readability.php": "^3.1",
        "phpoffice/phpword": "^1.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Wizdam\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wizdam\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit tests/",
        "test-coverage": "phpunit tests/ --coverage-html coverage/"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "extra": {
        "notes": [
            "guzzlehttp/guzzle — HTTP client with retry logic, replaces direct curl calls",
            "andreskrey/readability.php — extract main content from article URLs",
            "phpoffice/phpword — export analysis results to .docx",
            "Hugging Face Inference API — used via HTTP (no PHP package needed)",
            "pdftotext (Poppler) — system command via shell_exec()"
        ]
    }
}
