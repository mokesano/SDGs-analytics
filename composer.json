{
    "name": "wizdam/sdg-classifier",
    "description": "SDG Classification Application with PSR-4/PSR-12 standards",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Wizdam Team",
            "email": "team@wizdam.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "delight-im/auth": "^4.0",
        "guzzlehttp/guzzle": "^7.8",
        "andreskrey/readability.php": "^2.1",
        "phpoffice/phpword": "^1.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Wizdam\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wizdam\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage"
    }
}
